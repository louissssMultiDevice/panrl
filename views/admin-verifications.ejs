<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Verifications - NdiiClouD Admin</title>
    <link rel="stylesheet" href="/css/ndiicloud.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <div class="sidebar-logo-icon">🦖</div>
                <div class="sidebar-logo-text">
                    <h1>NdiiClouD</h1>
                    <p>Admin Panel</p>
                </div>
            </div>
        </div>
        
        <nav class="sidebar-nav">
            <div class="nav-section">
                <div class="nav-title">Management</div>
                <a href="/admin" class="nav-item">
                    <i class="fas fa-tachometer-alt"></i>
                    Dashboard
                </a>
                <a href="/admin/verifications" class="nav-item active">
                    <i class="fas fa-check-circle"></i>
                    Verifications
                    <% if (verifications.length > 0) { %>
                        <span class="nav-badge"><%= verifications.length %></span>
                    <% } %>
                </a>
                <a href="/admin/bots" class="nav-item">
                    <i class="fas fa-robot"></i>
                    All Bots
                </a>
                <a href="/admin/chats" class="nav-item">
                    <i class="fas fa-comments"></i>
                    Support Chats
                </a>
            </div>
        </nav>
    </aside>
    
    <main class="main-content">
        <header class="top-bar">
            <h2>Verification Requests</h2>
            <div class="user-menu">
                <div class="user-avatar"><%= user.name.charAt(0) %></div>
                <div class="user-info">
                    <div class="name"><%= user.name %></div>
                    <div class="role">Super Admin</div>
                </div>
            </div>
        </header>
        
        <div class="content">
            <div class="card">
                <div class="card-header">
                    <h3><i class="fas fa-clock"></i> Pending Verifications (<%= verifications.length %>)</h3>
                </div>
                <div class="card-body">
                    <% if (verifications.length === 0) { %>
                        <div class="empty-state">
                            <i class="fas fa-check-circle" style="font-size: 64px; color: var(--success);"></i>
                            <h4>No Pending Verifications</h4>
                            <p>All verification requests have been processed.</p>
                        </div>
                    <% } else { %>
                        <div class="verification-list">
                            <% verifications.forEach(v => { %>
                                <div class="verification-item" id="vrf-<%= v.id %>">
                                    <div class="verification-user">
                                        <% const usr = await db.findOne('users', { id: v.userId }); %>
                                        <div class="user-avatar"><%= usr?.name?.charAt(0) || '?' %></div>
                                        <div>
                                            <h4><%= usr?.name || 'Unknown' %></h4>
                                            <p><%= usr?.phone || '-' %> • <%= v.platform %></p>
                                        </div>
                                    </div>
                                    
                                    <div class="verification-proof">
                                        <% v.files.forEach(f => { %>
                                            <a href="<%= f.path %>" target="_blank" class="proof-image">
                                                <img src="<%= f.path %>" alt="Proof">
                                            </a>
                                        <% }) %>
                                    </div>
                                    
                                    <div class="verification-actions">
                                        <button class="btn btn-success" onclick="approve('<%= v.id %>')">
                                            <i class="fas fa-check"></i> Approve
                                        </button>
                                        <button class="btn btn-danger" onclick="reject('<%= v.id %>')">
                                            <i class="fas fa-times"></i> Reject
                                        </button>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>
    
    <style>
        .verification-list {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        
        .verification-item {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-lg);
            padding: 24px;
            display: grid;
            grid-template-columns: 250px 1fr auto;
            gap: 24px;
            align-items: center;
        }
        
        .verification-user {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        
        .verification-proof {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }
        
        .proof-image {
            width: 120px;
            height: 120px;
            border-radius: var(--radius-md);
            overflow: hidden;
            border: 2px solid var(--glass-border);
            transition: var(--transition-normal);
        }
        
        .proof-image:hover {
            border-color: var(--primary);
            transform: scale(1.05);
        }
        
        .proof-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .verification-actions {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        .verification-actions .btn {
            width: 140px;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px;
        }
        
        .empty-state h4 {
            margin: 16px 0 8px;
        }
        
        .empty-state p {
            color: var(--light-dim);
        }
    </style>
    
    <script>
        async function approve(id) {
            if (!confirm('Approve this verification?')) return;
            
            try {
                const res = await fetch(`/api/admin/verifications/${id}/review`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ decision: 'approved', notes: '' })
                });
                
                const data = await res.json();
                
                if (data.success) {
                    document.getElementById(`vrf-${id}`).remove();
                    Toast.success('Verification approved');
                }
            } catch (err) {
                Toast.error('Failed to approve');
            }
        }
        
        async function reject(id) {
            const reason = prompt('Reason for rejection:');
            if (reason === null) return;
            
            try {
                const res = await fetch(`/api/admin/verifications/${id}/review`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ decision: 'rejected', notes: reason })
                });
                
                const data = await res.json();
                
                if (data.success) {
                    document.getElementById(`vrf-${id}`).remove();
                    Toast.success('Verification rejected');
                }
            } catch (err) {
                Toast.error('Failed to reject');
            }
        }
    </script>
</body>
</html>
